# n8n application auth
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=StrongPassword123!

# Postgres configuration
POSTGRES_USER=n8n
POSTGRES_PASSWORD=ChangeMeNow!
POSTGRES_DB=n8n

# n8n database connection values
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=ChangeMeNow!

# Redis configuration for n8n queueing
QUEUE_BULL_REDIS_HOST=redis
QUEUE_BULL_REDIS_PORT=6379

# Optional compose project settings
# COMPOSE_PROJECT_NAME=n8n
